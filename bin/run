#!/usr/bin/env node

exports.initTimeStartTime = process.hrtime()
require('v8-compile-cache')

// Only use v8-compile-cache for Node.js versions below 20. It's necessary since v8-compile-cache does not compile esm modules.
// v8 has already been improved in Node.js 20 to cache esm modules, so v8-compile-cache is not needed anymore.
const nodeMajorVersion = parseInt(process.versions.node.split('.')[0], 10)
if (nodeMajorVersion < 20) {
  require('v8-compile-cache')
}

if (require.main === module) {
  require('@oclif/command')
    .run()
    .then(require('@oclif/command/flush'))
    .catch(require('@oclif/errors/handle'))
}
