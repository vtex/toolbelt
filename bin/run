#!/usr/bin/env node

exports.initTimeStartTime = process.hrtime()

const semver = require('semver')

// Load v8-compile-cache for Node.js versions below 20.
// v8-compile-cache speeds up subsequent script executions by caching the compiled
// bytecode generated by V8. This reduces startup time for CLI applications.
// We disable it for Node.js 20+ to avoid issues loading ESM modules.
// There is an open issue related to that here: https://github.com/zertosh/v8-compile-cache/issues/41
// and a not merged PR that would fix it: https://github.com/zertosh/v8-compile-cache/pull/47
if (semver.lt(process.versions.node, '20.0.0')) {
  require('v8-compile-cache')
}

// For Node.js versions 22.8.0 and above, enable the built-in compile cache,
// which provides similar functionality to v8-compile-cache.
// PR for the feature: https://github.com/nodejs/node/pull/54501
if (semver.gte(process.versions.node, '22.8.0')) {
  const module = require('node:module')
  module.enableCompileCache()
}

if (require.main === module) {
  require('@oclif/command')
    .run()
    .then(require('@oclif/command/flush'))
    .catch(require('@oclif/errors/handle'))
}
